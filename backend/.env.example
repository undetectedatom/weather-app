DEBUG=false
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
DATABASE_URL=sqlite:///./weather_app.db
AUTH_COOKIE_NAME=weather_app_auth
AUTH_COOKIE_SECRET=change-me-in-production
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com/v1
FORECAST_DAYS_DEFAULT=5
RECENT_LOCATIONS_LIMIT=5
UPSTREAM_TIMEOUT_SECONDS=8
